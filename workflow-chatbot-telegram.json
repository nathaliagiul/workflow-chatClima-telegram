    {
      "parameters": {
        "jsCode": "\nconst text = $json.queue || '';\nconst chatId = $('Telegram Trigger').item.json.message.chat.id;\n\nif (!chatId) {\n  return {\n    valido: false,\n    mensagemErro: \"❌ Não foi possível identificar o chat.\"\n  };\n}\n\nconst partes = text.split(',');\n\n// 1. Pega e normaliza a cidade\nlet cidade = partes[0] ? partes[0].trim() : '';\ncidade = cidade.normalize('NFD').replace(/[\\u0300-\\u036f]/g, '').toLowerCase();\n\n// 2. Pega e normaliza a UF\nlet uf = partes.length > 1 ? partes[1].trim() : '';\nuf = uf.normalize('NFD').replace(/[\\u0300-\\u036f]/g, '').toLowerCase();\n\n// 3. Verifica se a UF NÃO foi informada\nif (!uf) {\n  return { \n    valido: false, \n    chatId: chatId, \n    mensagemErro: \"⚠️ Formato inválido. Por favor, envie a mensagem no padrão: Cidade,Estado,País (Exemplo: São Paulo,SP,BR).\"\n  };\n}\n\n// 4. Se a UF existir, monta a queue com o 'br' no final\nlet queue = `${cidade},${uf},br`;\n\nreturn { \n  valido: true, \n  queue: queue, \n  chatId: chatId \n};"
      },
      "id": "6b404be5-7037-47f5-82ec-b5cd724e2940",
      "name": "Captura e Formatação",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1376,
        -128
      ]
    },
